# Awin Oufer US Weekly Report — credentials & config
# Copy to .env and fill in. NEVER commit .env (already in .gitignore).

# Awin advertiser console login
AWIN_EMAIL=affiliate@example.com
AWIN_PASSWORD=replace-me

# Awin merchant ID (Oufer Jewelry — US only)
AWIN_US_MERCHANT_ID=91941

# GitHub repo where rendered reports get committed (private, content store)
